meta {
  name: Update Service
  type: http
  seq: 4
}

patch {
  url: {{domain}}/services/:servicesId
  body: json
  auth: bearer
}

params:path {
  servicesId: {{service_id}}
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "title": "Updates Service title",
    "content": "updated content"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
