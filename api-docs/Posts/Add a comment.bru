meta {
  name: Add a comment
  type: http
  seq: 9
}

post {
  url: {{domain}}/posts/:postId/comments
  body: json
  auth: bearer
}

params:path {
  postId: {{post_id}}
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "content": "This is a comment",
   "parentId": "dd5b387c-a3a7-4639-aec8-efb2d4450d67" 
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
