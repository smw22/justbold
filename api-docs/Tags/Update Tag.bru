meta {
  name: Update Tag
  type: http
  seq: 4
}

patch {
  url: {{domain}}/tags/:tagTitle
  body: json
  auth: bearer
}

params:path {
  tagTitle: {{tag_title}}
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "title": "Updated Tag title"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
