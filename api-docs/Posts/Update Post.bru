meta {
  name: Update Post
  type: http
  seq: 4
}

patch {
  url: {{domain}}/posts/:postId
  body: json
  auth: bearer
}

params:path {
  postId: {{post_id}}
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "title": "Another Title",
    "content": "updated content"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
