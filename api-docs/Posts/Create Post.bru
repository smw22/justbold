meta {
  name: Create Post
  type: http
  seq: 3
}

post {
  url: {{domain}}/posts
  body: json
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "title": "Post title",
    "content": "This is the post content",
    "tags": "123",
    "media": "http://localhost:3000/image",
    "user_id": "1"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
