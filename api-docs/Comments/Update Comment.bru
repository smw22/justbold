meta {
  name: Update Comment
  type: http
  seq: 4
}

patch {
  url: {{domain}}/comments/:commentId
  body: json
  auth: bearer
}

params:path {
  commentId: {{comment_id}}
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "title": "Another Title",
    "content": "updated content"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
