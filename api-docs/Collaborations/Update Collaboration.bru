meta {
  name: Update Collaboration
  type: http
  seq: 4
}

patch {
  url: {{domain}}/collaborations/:collaborationId
  body: json
  auth: bearer
}

params:path {
  collaborationId: {{collaboration_id}}
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "title": "New Collab title",
    "content": "updated content"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
