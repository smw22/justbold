meta {
  name: Create User
  type: http
  seq: 3
}

post {
  url: {{domain}}/user
  body: json
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "name": "New User",
    "email": "new@user.com",
    "password": "123456",
    "phone": "12345678",
    "year_of_birth": 1996,
    "location": "Home",
    "subscription": "Free",
    "user_type": ""
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
