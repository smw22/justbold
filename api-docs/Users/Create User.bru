meta {
  name: Create User
  type: http
  seq: 3
}

post {
  url: {{domain}}/user
  body: json
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "name": "Test user",
    "email": "user@email.com",
    "password": "admin"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
