meta {
  name: Comment a Post
  type: http
  seq: 8
}

post {
  url: {{domain}}/posts/:postId/comments
  body: json
  auth: bearer
}

params:path {
  postId: {{post_id}}
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "content": "This is a comment",
    "parentId": "06f2b36b-99b5-4738-a115-17873c6023bd"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
